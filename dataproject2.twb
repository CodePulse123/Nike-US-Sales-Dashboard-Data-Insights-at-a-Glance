              <calculation class='tableau' formula='IF CONTAINS([Product], &quot;Men&apos;s Apparel&quot;) THEN &quot;Men&apos;s Apparel&quot;&#13;&#10;ELSEIF CONTAINS([Product], &quot;Men&apos;s Athletic Footwear&quot;) THEN &quot;Men&apos;s Athletic Footwear&quot;&#13;&#10;ELSEIF CONTAINS([Product], &quot;Women&apos;s Apparel&quot;) THEN &quot;Women&apos;s Apparel&quot;&#13;&#10;ELSEIF CONTAINS([Product], &quot;Women&apos;s Athletic Footwear&quot;) THEN &quot;Women&apos;s Athletic Footwear&quot;&#13;&#10;ELSEIF CONTAINS([Product], &quot;Kids&apos; Apparel&quot;) THEN &quot;Kids&apos; Apparel&quot;&#13;&#10;ELSEIF CONTAINS([Product], &quot;Kids&apos; Athletic Footwear&quot;) THEN &quot;Kids&apos; Athletic Footwear&quot;&#13;&#10;ELSE &quot;Other&quot;&#13;&#10;END' />
